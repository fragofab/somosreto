---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RETO — Reconciliación Total',
  description = 'Comunidad Cristiana en Guadalajara. Donde las relaciones se reconcilian, las vidas se transforman y los discípulos se multiplican.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
/* ═══════════════════════════════════════════════════════════════
   RETO · Design Tokens & Global Styles
   ═══════════════════════════════════════════════════════════════ */

*,*::before,*::after { margin:0; padding:0; box-sizing:border-box }

:root {
  /* Brand colors */
  --navy-900: #141a2d;
  --navy-800: #1b2337;
  --navy-700: #2f324e;
  --navy-500: #484c6f;
  --peach-400: #f2c5a3;
  --peach-300: #f7d7bd;
  --peach-200: #fbe6d3;
  --mint-400:  #bcd9c3;
  --mint-300:  #d1e4d4;
  --gold:      #e3be78;
  --gold-light:#f0d298;
  --cream-50:  #fefaf3;
  --cream-100: #fbf3e7;
  --cream-200: #f5e7db;
  --cream-300: #ecdac9;
  --silver-100:#e8e9ee;
  --silver-200:#cfd1da;
  --ink:       #141a2d;
  --ink-muted: rgba(20,26,45,.7);
  --ink-soft:  rgba(20,26,45,.5);
  --line:      rgba(20,26,45,.08);
  --line-2:    rgba(20,26,45,.14);

  /* Gradients */
  --grad-navy-peach:  radial-gradient(120% 90% at 0% 0%, #f2c5a3 0%, #a5887e 22%, #3b3d55 55%, #141a2d 100%);
  --grad-silver-cream:linear-gradient(115deg, #cfd1da 0%, #e0dfe2 45%, #f4eadd 100%);
  --grad-pill:        linear-gradient(90deg, #f2c5a3 0%, #bcd9c3 100%);
  --grad-accent:      linear-gradient(100deg, #a5887e 0%, #e3be78 40%, #f2c5a3 100%);

  /* Easing */
  --e-out:   cubic-bezier(.22, 1, .36, 1);
  --e-soft:  cubic-bezier(.16, 1, .3,  1);
  --e-spring:cubic-bezier(.34, 1.56, .64, 1);

  /* Radii */
  --r-xs:  10px;
  --r-sm:  14px;
  --r-md:  20px;
  --r-lg:  28px;
  --r-xl:  40px;
  --r-pill:999px;
}

html { scroll-behavior: smooth }

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background: var(--cream-100);
  color: var(--ink);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  letter-spacing: -.005em;
  line-height: 1.5;
}

img {
  display: block;
  max-width: 100%;
  user-select: none;
  -webkit-user-drag: none;
}

a { color: inherit; text-decoration: none; transition: color .4s var(--e-out) }
button { font-family: inherit }

/* ── Typography ── */
.serif { font-family: 'Fraunces', Georgia, serif; font-weight: 300; letter-spacing: -.025em }

h1, .h1 {
  font-family: 'Fraunces', serif; font-weight: 300;
  font-size: clamp(2.6rem, 6vw, 5.25rem);
  line-height: 1; letter-spacing: -.035em; color: var(--ink);
}
h2, .h2 {
  font-family: 'Fraunces', serif; font-weight: 300;
  font-size: clamp(2.1rem, 4.4vw, 3.75rem);
  line-height: 1.02; letter-spacing: -.03em; color: var(--ink);
}
h3, .h3 {
  font-family: 'Fraunces', serif; font-weight: 400;
  font-size: clamp(1.4rem, 2.4vw, 2rem);
  line-height: 1.1; letter-spacing: -.02em; color: var(--ink);
}
h4, .h4 {
  font-family: 'Inter', sans-serif; font-weight: 500;
  font-size: 1.0625rem; letter-spacing: -.01em; color: var(--ink);
}

.eyebrow {
  font-family: 'Inter', sans-serif;
  font-size: .6875rem; font-weight: 500;
  text-transform: uppercase; letter-spacing: .22em;
  color: var(--ink-muted);
}
.eyebrow-dot { display: inline-flex; align-items: center; gap: 10px }
.eyebrow-dot::before {
  content: '';
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--grad-pill);
}

.lead {
  font-size: clamp(1rem, 1.3vw, 1.1875rem);
  line-height: 1.55; color: var(--ink-muted); max-width: 52ch;
}

/* ── Layout ── */
.container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 32px;
}
@media (max-width: 900px) { .container { padding: 0 22px } }

/* ── Shared buttons ── */
.btn-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 22px 16px 26px;
  background: var(--ink); color: #fff;
  border-radius: var(--r-pill);
  font-size: .9375rem; font-weight: 500;
  transition: all .4s var(--e-out);
  cursor: pointer; border: none;
}
.btn-primary:hover {
  background: var(--navy-700);
  transform: translateY(-2px);
  box-shadow: 0 14px 30px -10px rgba(20,26,45,.35);
}
.btn-primary .arr {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--grad-pill);
  display: inline-flex; align-items: center; justify-content: center;
  color: var(--ink);
  transition: transform .4s var(--e-out);
}
.btn-primary:hover .arr { transform: rotate(-45deg) }
.btn-primary .arr svg { width: 10px; height: 10px }

.btn-whatsapp {
  display: inline-flex; align-items: center; gap: 12px;
  padding: 16px 22px 16px 26px;
  background: linear-gradient(135deg, #25D366 0%, #128C7E 100%); color: #fff;
  border-radius: var(--r-pill);
  font-size: .9375rem; font-weight: 500;
  transition: all .4s var(--e-out);
  box-shadow: 0 10px 24px -10px rgba(37,211,102,.55);
}
.btn-whatsapp:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 36px -12px rgba(37,211,102,.7);
}
.btn-whatsapp > svg { width: 22px; height: 22px; flex: none }
.btn-whatsapp .arr {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(255,255,255,.2);
  display: inline-flex; align-items: center; justify-content: center;
  transition: transform .4s var(--e-out);
}
.btn-whatsapp .arr svg { width: 10px; height: 10px }
.btn-whatsapp:hover .arr { transform: rotate(-45deg) }

/* ── Reveal animations ── */
.reveal {
  opacity: 0; transform: translateY(28px);
  transition: opacity 1s var(--e-soft), transform 1s var(--e-soft);
}
.reveal.in       { opacity: 1; transform: translateY(0) }
.reveal.d1       { transition-delay: .1s }
.reveal.d2       { transition-delay: .2s }
.reveal.d3       { transition-delay: .3s }
.reveal.d4       { transition-delay: .4s }
.reveal-scale    { opacity: 0; transform: scale(.96); transition: opacity 1s var(--e-soft), transform 1.1s var(--e-soft) }
.reveal-scale.in { opacity: 1; transform: scale(1) }
.reveal-left     { opacity: 0; transform: translateX(-24px); transition: opacity 1s var(--e-soft), transform 1s var(--e-soft) }
.reveal-left.in  { opacity: 1; transform: translateX(0) }
.reveal-right    { opacity: 0; transform: translateX(24px); transition: opacity 1s var(--e-soft), transform 1s var(--e-soft) }
.reveal-right.in { opacity: 1; transform: translateX(0) }

/* ── Scrollbar ── */
::-webkit-scrollbar        { width: 10px; height: 10px }
::-webkit-scrollbar-track  { background: var(--cream-200) }
::-webkit-scrollbar-thumb  { background: var(--navy-700); border-radius: 999px }
::-webkit-scrollbar-thumb:hover { background: var(--ink) }

::selection { background: var(--peach-400); color: var(--ink) }
</style>