---
// Footer.astro
import { asset } from '../utils/asset';
---

<footer>
  <div class="container">
    <div class="footer-row">
      <a class="mark" href="#top" aria-label="RETO">
        <img src={asset('logos/Logo-RETO-2026-05.png')} alt="RETO" />
      </a>
      <nav class="footer-nav" aria-label="Footer">
        <a href="#fundamentos">Fundamentos</a>
        <span class="footer-dot" aria-hidden="true"></span>
        <a href="#ministerios">Ministerios</a>
        <span class="footer-dot" aria-hidden="true"></span>
        <a href="#contacto">Contacto</a>
        <span class="footer-dot" aria-hidden="true"></span>
        <a href="#visit">Visítanos</a>
      </nav>
      <div class="footer-socials" aria-label="Redes sociales">
        <a href="https://facebook.com/somos.reto" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.5 9.87v-6.99H8v-2.88h2.5V9.84c0-2.47 1.47-3.83 3.72-3.83 1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.23 0-1.61.76-1.61 1.55v1.86h2.74l-.44 2.88h-2.3v6.99A10 10 0 0 0 22 12z"/></svg>
        </a>
        <a href="https://instagram.com/somos.reto" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© RETO Comunidad Cristiana · Todos los derechos reservados</span>
    </div>
  </div>
</footer>

<style is:global>
footer {
  background: var(--navy-900); color: rgba(255,255,255,.7);
  padding: 84px 0 44px; position: relative; overflow: hidden;
}
footer::before {
  content: ''; position: absolute; top: -100px; left: -100px;
  width: 300px; height: 300px; border-radius: 50%;
  background: var(--grad-pill); filter: blur(100px); opacity: .15;
}
.footer-row {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 1fr 2.2fr 1fr;
  gap: 42px; align-items: center;
}
.footer-row .mark { display: inline-flex; align-items: center; justify-self: start }
.footer-row .mark img { height: 100px; width: auto; display: block }
.footer-nav {
  display: flex; gap: 26px; justify-content: center;
  align-items: center; flex-wrap: wrap;
}
.footer-nav a { font-size: .95rem; color: rgba(255,255,255,.74); transition: color .3s var(--e-out) }
.footer-nav a:hover { color: #f2c5a3 }
.footer-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--grad-pill); display: inline-block; flex-shrink: 0;
}
.footer-socials { display: flex; gap: 12px; align-items: center; justify-self: end }
.footer-socials a {
  width: 46px; height: 46px; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--grad-pill); color: var(--navy-900);
  transition: all .4s var(--e-out);
}
.footer-socials a:hover { filter: brightness(1.08); transform: translateY(-2px); box-shadow: 0 14px 26px -14px rgba(242,197,163,.55) }
.footer-socials a svg { width: 18px; height: 18px }
.footer-bottom {
  position: relative; z-index: 2;
  margin-top: 46px; padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,.08);
  display: flex; justify-content: flex-start;
  font-size: .8125rem; color: rgba(255,255,255,.4);
}

@media (max-width: 760px) {
  footer { padding: 64px 0 36px }
  .footer-row { grid-template-columns: 1fr; gap: 28px; text-align: center }
  .footer-row .mark { justify-content: center }
  .footer-nav { justify-content: center }
  .footer-socials { justify-content: center }
}
</style>