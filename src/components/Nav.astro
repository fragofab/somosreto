---
// Nav.astro — Pill flotante centrado, navy permanente, backdrop-blur
---

<nav id="mainNav">
  <div class="nav-inner">
    <div class="nav-left">
      <a href="#fundamentos">Fundamentos</a>
      <a href="#ministerios">Ministerios</a>
    </div>
    <a class="nav-brand" href="#top" aria-label="RETO">
      <img src="/Logo-RETO-2026-No-slogan.png" alt="RETO" />
    </a>
    <div class="nav-right">
      <a href="#contacto">Contacto</a>
      <a href="#visit">Visítanos</a>
    </div>
    <button class="mobile-toggle" aria-label="Abrir menú">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</nav>

<style is:global>
nav {
  position: fixed; top: 16px; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: center;
  transition: top .5s var(--e-out);
}
.nav-inner {
  width: min(750px, calc(100% - 48px));
  display: grid; grid-template-columns: 1fr auto 1fr;
  align-items: center; gap: 28px;
  padding: 12px 32px;
  background: rgba(20,26,45,.92);
  backdrop-filter: blur(22px) saturate(1.3);
  -webkit-backdrop-filter: blur(22px) saturate(1.3);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--r-pill);
  box-shadow: 0 18px 44px -16px rgba(20,26,45,.45);
}
.nav-left, .nav-right {
  display: flex; align-items: center; gap: 40px;
}
.nav-left  { justify-content: flex-end }
.nav-right { justify-content: flex-start }
.nav-left a, .nav-right a {
  position: relative;
  font-size: .875rem; font-weight: 500;
  color: rgba(255,255,255,.72);
  white-space: nowrap; padding: 4px 0;
  transition: color .4s var(--e-out);
}
.nav-left a::after, .nav-right a::after {
  content: '';
  position: absolute; left: 50%; bottom: 0;
  height: 1.5px; width: 0;
  background: linear-gradient(95deg, #f2c5a3 0%, #e3be78 50%, #f2c5a3 100%);
  border-radius: 2px;
  transform: translateX(-50%);
  transition: width .4s var(--e-out);
}
.nav-left a:hover, .nav-right a:hover { color: #fff }
.nav-left a:hover::after, .nav-right a:hover::after { width: 100% }

.nav-brand {
  position: relative; display: inline-flex;
  align-items: center; justify-content: center;
  line-height: 0; padding: 0 16px;
}
.nav-brand img { height: 55px; width: auto; display: block }

.mobile-toggle {
  display: none; background: transparent;
  border: 0; padding: 10px; cursor: pointer;
}
.mobile-toggle svg { width: 22px; height: 22px; stroke: #fff; fill: none }

/* Mobile panel */
.mobile-panel {
  position: absolute; top: calc(100% + 10px); left: 20px; right: 20px;
  display: none; flex-direction: column; gap: 6px;
  background: rgba(254,250,243,.97);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  padding: 14px 18px 18px;
  border-radius: var(--r-md);
  border: 1px solid rgba(20,26,45,.06);
  box-shadow: 0 24px 48px -20px rgba(20,26,45,.25);
  z-index: 101;
}
.mobile-panel.is-open { display: flex }
.mobile-panel-close {
  align-self: flex-end;
  background: transparent; border: 0; padding: 6px;
  cursor: pointer; color: var(--ink); opacity: .6;
  transition: opacity .3s var(--e-out);
  margin: -4px -4px 0 0;
}
.mobile-panel-close:hover { opacity: 1 }
.mobile-panel-close svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2 }
.mobile-panel a {
  font-size: .95rem; font-weight: 500; color: var(--ink);
  padding: 10px 12px; border-radius: var(--r-sm);
  transition: background .25s var(--e-out);
}
.mobile-panel a:hover { background: rgba(20,26,45,.05) }

@media (max-width: 900px) {
  .nav-left, .nav-right { display: none }
  .nav-inner { grid-template-columns: 1fr auto 1fr }
  .mobile-toggle { display: inline-flex; justify-self: end; grid-column: 3 }
}

.mobile-panel { display: none }
.mobile-panel.is-open { display: flex }
</style>

<script>
const toggle = document.querySelector('.mobile-toggle') as HTMLButtonElement | null;
const navEl  = document.querySelector('nav .nav-inner') as HTMLElement | null;

if (toggle && navEl) {
  const panel = document.createElement('div');
  panel.className = 'mobile-panel';
  panel.innerHTML = `
    <button class="mobile-panel-close" type="button" aria-label="Cerrar menú">
      <svg viewBox="0 0 24 24" stroke-linecap="round">
        <path d="M6 6L18 18M18 6L6 18"/>
      </svg>
    </button>
    <a href="#fundamentos">Fundamentos</a>
    <a href="#ministerios">Ministerios</a>
    <a href="#contacto">Contacto</a>
    <a href="#visit">Visítanos</a>
  `;
  navEl.appendChild(panel);

  const close = () => panel.classList.remove('is-open');

  toggle.addEventListener('click', () => panel.classList.toggle('is-open'));
  panel.querySelector('.mobile-panel-close')?.addEventListener('click', close);
  panel.querySelectorAll('a').forEach(a => a.addEventListener('click', close));

  document.addEventListener('click', (e) => {
    if (!panel.classList.contains('is-open')) return;
    if (!panel.contains(e.target as Node) && !toggle.contains(e.target as Node)) close();
  });
}
</script>