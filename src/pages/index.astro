---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Fundamentos from "../components/Fundamentos.astro";
import Ministerios from "../components/Ministerios.astro";
import Contacto from "../components/Contacto.astro";
import Visit from "../components/Visit.astro";
import Footer from "../components/Footer.astro";
import FabWhatsapp from "../components/FabWhatsapp.astro";
---

<BaseLayout>
  <Nav />
  <Hero />
  <Fundamentos />
  <Ministerios />
  <Contacto />
  <Visit />
  <Footer />
  <FabWhatsapp />
</BaseLayout>

<style is:global>
  .fab-whatsapp {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #25d366;
    color: #fff;
    border-radius: 50%;
    text-decoration: none;
    box-shadow:
      0 14px 36px -10px rgba(37, 211, 102, 0.55),
      0 4px 12px -4px rgba(20, 26, 45, 0.18);
    transition:
      transform 0.4s var(--e-out),
      box-shadow 0.4s var(--e-out),
      background 0.3s var(--e-out);
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
  }
  .fab-whatsapp.is-visible {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .fab-whatsapp:hover {
    transform: translateY(-2px);
    background: #1ebe5b;
    box-shadow:
      0 22px 44px -12px rgba(37, 211, 102, 0.7),
      0 6px 16px -4px rgba(20, 26, 45, 0.22);
  }
  .fab-whatsapp svg {
    width: 30px;
    height: 30px;
    flex: none;
  }
  .fab-whatsapp::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(37, 211, 102, 0.6);
    animation: fab-pulse 2.4s var(--e-soft) infinite;
    pointer-events: none;
  }
  @keyframes fab-pulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.18);
      opacity: 0;
    }
  }
  @media (max-width: 600px) {
    .fab-whatsapp {
      right: 16px;
      bottom: 16px;
      width: 54px;
      height: 54px;
    }
    .fab-whatsapp svg {
      width: 26px;
      height: 26px;
    }
  }
</style>

<script>
  // ── Scroll: nav state + FAB visibility ──
  const nav = document.getElementById("mainNav");
  const fab = document.getElementById("fabWhatsapp");

  window.addEventListener(
    "scroll",
    () => {
      if (nav) {
        nav.classList.toggle("scrolled", window.scrollY > 40);
      }
      if (fab) {
        fab.classList.toggle("is-visible", window.scrollY > 400);
      }
    },
    { passive: true },
  );

  // ── Reveal on scroll ──
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: "0px 0px -60px 0px" },
  );

  document
    .querySelectorAll(".reveal, .reveal-scale, .reveal-left, .reveal-right")
    .forEach((el) => io.observe(el));

  // ── Parallax: visit photo + map ──
  (function () {
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.matchMedia("(max-width: 900px)").matches;
    if (reduce) return;

    const dataPxEls = document.querySelectorAll<HTMLElement>("[data-parallax]");
    const mapEl = document.querySelector<HTMLElement>(".contacto-map");

    let ticking = false;

    function update(): void {
      const vh = window.innerHeight;

      if (!isMobile && dataPxEls.length) {
        dataPxEls.forEach((el) => {
          const section = el.closest("section");
          if (!section) return;
          const rect = section.getBoundingClientRect();
          // Solo mover si la sección está cerca del viewport
          if (rect.top > vh * 2) return;
          const distFromCenter = rect.top + rect.height / 2 - vh / 2;
          const speed = parseFloat(el.dataset.parallax ?? "0.22");
          el.style.transform = `translate3d(0, ${-distFromCenter * speed}px, 0)`;
        });
      }

      if (mapEl) {
        const rect = mapEl.getBoundingClientRect();
        if (rect.top < vh && rect.bottom > 0) {
          const progress = (vh - rect.top) / (vh + rect.height);
          const iframe = mapEl.querySelector<HTMLElement>("iframe");
          if (iframe)
            iframe.style.transform = `translateY(${(progress - 0.5) * -20}px) scale(1.04)`;
        }
      }

      ticking = false;
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );

    window.addEventListener(
      "resize",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );

    // Esperar a que el layout esté completamente calculado
    requestAnimationFrame(() => {
      requestAnimationFrame(update);
    });
  })();
</script>
